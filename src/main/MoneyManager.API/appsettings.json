    "DefaultConnection": ""
  },
  "ApplicationInsights": {
    "ConnectionString": ""
  },
  "DetailedErrors": false,
  "Data": {
    "UseInMemoryDatabase": false
  },
  "HealthChecks": {
    "IncludeDatabaseInReadiness": false,
    "CommandTimeoutSeconds": 90
  },
  "RateLimiting": {
    "Health": {
      "PermitLimit": 300
    },
    "HealthDb": {
      "PermitLimit": 90
    },
    "Api": {
      "PermitLimit": 500
    }
